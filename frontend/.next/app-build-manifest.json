{
  "pages": {
    "/[locale]/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/[locale]/layout.css",
      "static/chunks/app/[locale]/layout.js"
    ],
    "/[locale]/not-found": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/[locale]/not-found.js"
    ],
    "/[locale]/(website)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/[locale]/(website)/layout.js"
    ],
    "/[locale]/(website)/(Index)/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/[locale]/(website)/(Index)/page.css",
      "static/chunks/app/[locale]/(website)/(Index)/page.js"
    ]
  }
}